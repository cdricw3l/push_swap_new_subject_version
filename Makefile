br: bonus
	@ $(VAL) ./checker/checker "120 12 587"

clean:
	rm -rf $(SRCS_OBJS) $(BONUS_OBJS) $(VALGRIND_LOG)

fclean: clean
	rm -rf $(NAME) $(BONUS_NAME)

re: fclean $(NAME)

COM=push_swap_generic

git: fclean
	git add .
	git commit -m $(COM)
	git push origin $(shell git branch --show-current)

libft:
	make -C $(LIBFT_PATH)

.PHONY: all clean fclean re as home libft git  middle simple bonus